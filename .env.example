# Copy to .env.local and fill in.

# Groq (LLM) — free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxx
# Optional: text + vision model overrides (must support tool use / vision on Groq)
MANTIS_MODEL=llama-3.3-70b-versatile
MANTIS_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# MOSS (vector retrieval) — free project at https://moss.dev
# If unset, the app falls back to feeding the full manual to the LLM.
MOSS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MOSS_PROJECT_KEY=moss_xxxxx

# Video transcription — your Hugging Face Space running Whisper.
# Contract: POST multipart field "audio" (mp3) -> JSON { text, segments:[{start,end,text}] }
# If unset, video upload is disabled (PDF/text still work).
HF_TRANSCRIBE_URL=https://your-space.hf.space/transcribe
HF_TOKEN=hf_xxxxx
